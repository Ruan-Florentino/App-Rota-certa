{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "isPro": { "type": "boolean" },
        "travelInterests": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A travel itinerary generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "budget": { "type": "number" },
        "itinerary": { "type": "array" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "destination", "itinerary"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or social notification for a user.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "clone", "reminder", "tip"] },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "message", "read", "createdAt"]
    },
    "SocialPost": {
      "title": "SocialPost",
      "description": "A post in the travel social feed.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "media": { "type": "array" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "shares": { "type": "number" },
        "saves": { "type": "number" },
        "location": { "type": "string" },
        "tripId": { "type": "string" },
        "isPro": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    },
    "Story": {
      "title": "Story",
      "description": "A temporary story (24h).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "media": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "media", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Saved travel itineraries."
    },
    "/notifications/{userId}/items/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    },
    "/social_posts/{postId}": {
      "schema": "SocialPost",
      "description": "Social feed posts."
    },
    "/social_posts/{postId}/likes/{userId}": {
      "schema": { "type": "object", "properties": { "createdAt": { "type": "string" } } },
      "description": "Post likes."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Temporary stories."
    }
  }
}
