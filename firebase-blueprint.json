{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A travel itinerary generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "destination": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "budget": { "type": "number" },
        "type": { "type": "string" },
        "itinerary": { "type": "array" },
        "costs": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "destination", "itinerary"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Saved travel itineraries."
    }
  }
}
