rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['userId', 'destination', 'itinerary']) &&
             data.userId == request.auth.uid &&
             data.destination is string &&
             data.destination.size() < 200 &&
             data.itinerary is list;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Trips
    match /trips/{tripId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTrip(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid) && isValidTrip(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid);
    }
  }
}
