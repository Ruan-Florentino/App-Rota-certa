# ============================================
# RIGHT WAY — VARIÁVEIS DE PRODUÇÃO OBRIGATÓRIAS
# ============================================
# Configurar no provedor (Vercel/Railway/etc),
# NUNCA commitar valores reais.

# --- CLIENT (expostas no bundle, OK) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_MAPTILER_KEY=

# --- SERVER (SECRET — nunca prefixar VITE_) ---
FIREBASE_SERVICE_ACCOUNT=  # JSON completo da service account (string única)
GEMINI_API_KEY=            # https://aistudio.google.com/apikey
MP_ACCESS_TOKEN=           # Token de produção do MercadoPago

# --- RUNTIME ---
NODE_ENV=production
PORT=8080
ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com
